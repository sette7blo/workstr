# Workstr local configuration. Copy to .env and edit. Do not commit .env.

# Link to Idenstr (the Chief: holds your key, signs your sheet, publishes summaries).
# Workstr is independent and may run anywhere — reach Idenstr by its address on
# your network: its LAN IP or its Tailscale IP/hostname, your choice.
# Generate a token in Idenstr > API tokens with scopes:
#   profile:read, sign:kind:30078, publish:kind:1
WORKSTR_IDENSTR_URL=http://<idenstr-lan-or-tailscale-address>:3000
WORKSTR_IDENSTR_TOKEN=idstr_paste_token_here

# Read-only access to Idenstr's local relay (the write-ahead vault). Same as above:
# use the relay's address on your network (LAN or Tailscale), your choice. Optional.
WORKSTR_LOCAL_RELAY=ws://<idenstr-lan-or-tailscale-address>:7777

# No dashboard login by default: Workstr relies on the network boundary and its
# scoped Idenstr token (Idenstr is the app that holds the login). To optionally
# turn on HTTP Basic auth, set both of these. For exposure beyond a trusted
# network, put Workstr behind an HTTPS reverse proxy.
# WORKSTR_AUTH_USER=
# WORKSTR_AUTH_PASSWORD=

# Binding. Default 0.0.0.0 so the app is reachable over your LAN or Tailscale mesh.
# Set 127.0.0.1 for a local-only install.
WORKSTR_HOST_BIND=0.0.0.0
WORKSTR_HOST_PORT=3003
